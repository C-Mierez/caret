{
	"name": "caret",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev:only": "next dev",
		"dev": "bunx --bun concurrently \"bun run dev:only\" \"bun run convex\"",
		"convex": "bunx --bun convex dev",
		"inngest": "npx --ignore-scripts=false inngest-cli@latest dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"format": "biome format --write",
		"env:sync": "bunx --bun env-sync sync",
		"env:check": "bunx --bun env-sync check",
		"postinstall": "lefthook install"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.64",
		"@ai-sdk/google": "^3.0.53",
		"@base-ui/react": "^1.3.0",
		"@clerk/nextjs": "^7.0.6",
		"@clerk/ui": "^1.2.3",
		"@t3-oss/env-nextjs": "^0.13.11",
		"ai": "^6.0.138",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"convex": "^1.34.0",
		"inngest": "^4.1.0",
		"lucide-react": "^1.0.1",
		"next": "16.2.1",
		"next-themes": "^0.4.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"shadcn": "^4.1.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
