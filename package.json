		"@clerk/ui": "^1.2.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@inngest/middleware-sentry": "^1.0.0",
		"@mendable/firecrawl-js": "^4.18.0",
		"@react-symbols/icons": "^1.3.1",
		"@replit/codemirror-indentation-markers": "^6.5.3",
		"@replit/codemirror-minimap": "^0.5.2",
		"@sentry/nextjs": "10",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-form": "^1.28.5",
		"@types/http-errors": "^2.0.5",
		"ai": "^6.0.138",
		"allotment": "^1.20.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"codemirror": "^6.0.2",
		"convex": "^1.34.1",
		"date-fns": "^4.1.0",
		"http-errors": "^2.0.1",
		"inngest": "^4.1.0",
		"lucide-react": "^1.7.0",
		"next": "16.2.1",
		"next-themes": "^0.4.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-icons": "^5.6.0",
		"shadcn": "^4.1.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"unique-names-generator": "^4.7.1",
		"vaul": "^1.1.2",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@c-mierez/biome-config": "github:c-mierez/biome-config",
		"@c-mierez/env-sync": "github:c-mierez/env-sync",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/react": "^19",
