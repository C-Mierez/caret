{
	"name": "caret",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev:only": "next dev",
		"dev": "bunx --bun concurrently \"bun run dev:only\" \"bun run convex\"",
		"convex": "bunx --bun convex dev",
		"inngest": "npx --ignore-scripts=false inngest-cli@latest dev",
		"build": "next build",
		"start:only": "next start",
		"start": "bunx --bun concurrently \"bun run start:only\" \"bun run convex\"",
		"lint:check": "biome check",
		"lint:fix": "biome lint --write",
		"format": "biome format --write",
		"env:sync": "bunx --bun env-sync sync",
		"env:check": "bunx --bun env-sync check",
		"postinstall": "lefthook install"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.64",
		"@ai-sdk/google": "^3.0.53",
		"@base-ui/react": "^1.3.0",
